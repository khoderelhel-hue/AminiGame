#include <iostream>
using namespace std;

int *resizeArrayUp(int *oldArray, int oldSize, int newSize);
int *resizeArrayDown(int *oldArray, int oldSize, int newSize);

int main()
{
    int n{0};
    int m{0};
    cout << "How many elements should the array have? : ";
    cin >> n;

    int *oldArray = new int[n]();

    for (int i = 0; i < n; i++)
    {
        cout << "Enter element " << i + 1 << ": ";
        cin >> oldArray[i];
    }
    for (int i = 0; i < n; i++)
    {
        cout << "Element " << i + 1 << ": " << oldArray[i] << endl;
    }

    cout << "Enter the new size of the array: ";
    cin >> m;

    int *newArray = new int[m]();
    if (m > n)
    {
        newArray = resizeArrayUp(oldArray, n, m);
    }
    else
        newArray = resizeArrayDown(oldArray, n, m);

    for (int i = 0; i < m; i++)
    {
        cout << "Element " << i + 1 << ": " << newArray[i] << endl;
    }

    delete[] newArray;
    newArray = nullptr;

    return 0;
}

int *resizeArrayUp(int *oldArray, int oldSize, int newSize)
{
    int *newArr = new int[newSize];
    for (int i = 0; i < oldSize; i++)
    {
        newArr[i] = oldArray[i];
    }
    for (int i = oldSize; i < newSize; i++)
    {
        cout << "Enter new element " << i + 1 << ": ";
        cin >> newArr[i];
    }

    delete[] oldArray;
    oldArray = nullptr;

    return newArr;
}

int *resizeArrayDown(int *oldArray, int oldSize, int newSize)
{
    int *newArr = new int[newSize];
    for (int i = 0; i < newSize; i++)
    {
        newArr[i] = oldArray[i];
    }

    cout << oldSize - newSize << " element(s) have been removed from the end of the array." << endl;

    delete[] oldArray;
    oldArray = nullptr;

    return newArr;
}
